{
  "extends": "@repo/typescript-config/nextjs.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "@repo/core": ["../../packages/core/index.ts"],
      "@repo/core/*": ["../../packages/core/*"],
      "@repo/domain": ["../../packages/domain/index.ts"],
      "@repo/domain/*": ["../../packages/domain/*"],
      "@repo/state": ["../../packages/state/index.ts"],
      "@repo/state/*": ["../../packages/state/*"],
      "@repo/theme": ["../../packages/theme/index.ts"],
      "@repo/theme/*": ["../../packages/theme/*"],
      "@repo/ui-web": ["../../packages/ui-web/index.ts"],
      "@repo/ui-web/*": ["../../packages/ui-web/*"],
      "@repo/i18n": ["../../packages/i18n/index.ts"],
      "@repo/i18n/*": ["../../packages/i18n/*"],
      "@repo/ui-contracts": ["../../packages/ui-contracts/index.ts"],
      "@repo/ui-contracts/*": ["../../packages/ui-contracts/*"]
    },
    "plugins": [{ "name": "next" }]
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    "../../packages/*/index.ts",
    "../../packages/**/*.ts",
    "../../packages/**/*.tsx"
  ],
  "exclude": ["node_modules"]
}
