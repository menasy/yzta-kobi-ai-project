# ============================================
# KOBİ AI Agent — Environment Variables
# ============================================
# Bu dosyayı .env olarak kopyalayın ve değerleri güncelleyin.
# cp .env.example .env

# ---------- Uygulama ----------
APP_NAME=KOBİ Agent
APP_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=true
API_PREFIX=/api
CORS_ORIGINS=["http://localhost:3000"]

# ---------- Veritabanı ----------
# Docker Compose tarafından override edilir, local geliştirme için:
DATABASE_URL=postgresql+asyncpg://kobi_user:kobi_pass@localhost:5432/kobi_db
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=5
DATABASE_ECHO=false

# ---------- Redis ----------
# Docker Compose tarafından override edilir, local geliştirme için:
REDIS_URL=redis://localhost:6379/0
REDIS_CONVERSATION_TTL=86400

# ---------- Güvenlik ----------
# Minimum 32 karakter, rastgele üretilmiş bir string kullanın
# python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=CHANGE-ME-generate-a-secure-random-key-at-least-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ---------- LLM ----------
LLM_API_KEY=sk-ant-your-api-key-here
LLM_MODEL=claude-sonnet-4-20250514

# ---------- Kargo (opsiyonel) ----------
USE_MOCK_CARGO=true
CARGO_API_KEY=

# ---------- Logging ----------
LOG_LEVEL=INFO
LOG_JSON=true
