# ============================================
# KOBİ AI Agent — Environment Variables (Template)
# ============================================
# Bu dosyayı .env olarak kopyalayın ve değerleri güncelleyin.
# cp .env.example .env

# ---------- Uygulama ----------
APP_NAME=KOBİ Agent
APP_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=true
API_PREFIX=/api
CORS_ORIGINS=["http://localhost:3000"]

# ---------- PostgreSQL (Docker Yapılandırması) ----------
POSTGRES_DB=kobi_db
POSTGRES_USER=kobi_user
POSTGRES_PASSWORD=kobi_pass
POSTGRES_PORT=5433

# ---------- Redis (Docker Yapılandırması) ----------
REDIS_PORT=6380

# ---------- Bağlantı Bilgileri (Backend İçin) ----------
# NOT: Backend Docker içinden bağlandığı için host olarak servis adlarını (db, redis) kullanır.
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}
REDIS_URL=redis://redis:6379/0

# ---------- Veritabanı Havuzu ----------
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=5
DATABASE_ECHO=false

# ---------- Redis Ayarları ----------
REDIS_CONVERSATION_TTL=86400

# ---------- Güvenlik ----------
# Minimum 32 karakter, rastgele üretilmiş bir string kullanın
# python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=CHANGE-ME-generate-a-secure-random-key-at-least-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ---------- LLM (Anthropic) ----------
LLM_API_KEY=sk-ant-your-api-key-here
LLM_MODEL=claude-sonnet-4-20250514

# ---------- Kargo (Opsiyonel) ----------
USE_MOCK_CARGO=true
CARGO_API_KEY=

# ---------- Logging ----------
LOG_LEVEL=INFO
LOG_JSON=true
