# ============================================
# KOBİ AI Agent — Development Environment
# ============================================

# ---------- Uygulama ----------
APP_NAME=KOBİ Agent
APP_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=true
API_PREFIX=/api
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000","http://localhost:5173","http://127.0.0.1:5173"]

# ---------- PostgreSQL (Docker Yapılandırması) ----------
POSTGRES_DB=kobi_db
POSTGRES_USER=kobi_user
POSTGRES_PASSWORD=kobi_pass
POSTGRES_PORT=5433

# ---------- Redis (Docker Yapılandırması) ----------
REDIS_PORT=6380

# ---------- Bağlantı Bilgileri (Backend İçin) ----------
# Docker içinden bağlantı için host 'db' ve 'redis' servis isimleridir.
DATABASE_URL=postgresql+asyncpg://kobi_user:kobi_pass@db:5432/kobi_db
REDIS_URL=redis://redis:6379/0

# ---------- Veritabanı Havuzu ----------
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=5
DATABASE_ECHO=false

# ---------- Redis Ayarları ----------
REDIS_CONVERSATION_TTL=86400

# ---------- Güvenlik ----------
SECRET_KEY=dev-only-secret-key-change-in-production-min-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# ---------- LLM (Gemini) ----------
LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.5-flash
GEMINI_API_KEY=Your_Gemini_API_Key_Here

# ---------- Kargo ----------
USE_MOCK_CARGO=true
CARGO_API_KEY=

# ---------- Logging ----------
LOG_LEVEL=DEBUG
LOG_JSON=true

# ---------- Seed Data (Development) ----------
SEED_ADMIN_EMAIL=admin@kobi.local
SEED_ADMIN_PASSWORD=Admin123!
SEED_OPERATOR_EMAIL=operasyon@kobi.local
SEED_OWNER_EMAIL=isletme@kobi.local
SEED_DEMO_EMAIL=demo@kobi.local
SEED_DEMO_PASSWORD=Demo12345!
    
REFRESH_TOKEN_EXPIRE_MINUTES=10080
AUTH_ACCESS_COOKIE_NAME=access_token
AUTH_REFRESH_COOKIE_NAME=refresh_token
AUTH_COOKIE_PATH=/
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_HTTPONLY=true
AUTH_COOKIE_SAMESITE=lax
AUTH_COOKIE_DOMAIN=
